suggest_btn = tk.Button(suggest_frame, text="Generate Suggestion", font=("Helvetica", 10, "bold"), bg="#2ecc71", fg="white", command=suggest_password)
suggest_btn.pack(fill="x", pady=(0, 10))

suggestion_entry = tk.Entry(suggest_frame, font=("Helvetica", 12, "bold"), justify="center")
suggestion_entry.pack(fill="x")

